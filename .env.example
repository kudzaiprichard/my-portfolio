# =============================================================================
# Environment Variables — copy this file to .env.local and fill in your values
#
#   cp .env.example .env.local
#
# NEXT_PUBLIC_* variables are inlined at build time and visible to the browser.
# Variables without that prefix are server-only and never reach the client.
# =============================================================================


# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------

# Canonical origin of the site — used in OG/Twitter meta tags, sitemap, robots,
# and JSON-LD structured data.  No trailing slash.
# Default (dev): http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://your-domain.com


# -----------------------------------------------------------------------------
# Contact
# -----------------------------------------------------------------------------

# Your public-facing email address.  Shown in the contact section and used as
# the reply-to address for form submissions.
NEXT_PUBLIC_EMAIL=you@example.com

# Resend API key — server-only, used by /api/contact to send contact-form emails.
# Create a free key at https://resend.com/api-keys
# Required: contact form returns HTTP 500 without it.
RESEND_API_KEY=re_YOUR_API_KEY_HERE


# -----------------------------------------------------------------------------
# Social links  (full URLs used in nav, footer, and JSON-LD)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_GITHUB_URL=https://github.com/your-username
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/your-username
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/your-username


# -----------------------------------------------------------------------------
# Social handles  (short display strings, e.g. for Twitter card `creator` tag)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_GITHUB_HANDLE=@your-username
NEXT_PUBLIC_TWITTER_HANDLE=@your-username
NEXT_PUBLIC_LINKEDIN_NAME=Your Full Name


# -----------------------------------------------------------------------------
# Resume
# -----------------------------------------------------------------------------

# URL or path to your résumé/CV file.
# Can be an absolute URL (e.g. a Google Drive share link) or a root-relative
# path served from /public (e.g. /resume.pdf).
# Default: /resume.pdf
NEXT_PUBLIC_RESUME_URL=/resume.pdf
